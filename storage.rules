rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /bosses/{userId}/{fileName} {
      // Anyone can read/download the assets
      allow read: if true;
      // Only authenticated users can upload to their own folder
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024; // 50MB max limit
    }
  }
}
