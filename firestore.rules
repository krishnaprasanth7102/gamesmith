rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@overwatch.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.resource != null && request.resource.data.get('master_bypass', '') == 'OVERWATCH_BYPASS_2026') ||
        (resource != null && resource.data.get('master_bypass', '') == 'OVERWATCH_BYPASS_2026')
      );
    }

    function canReadAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@overwatch.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || 
             (userId == 'OVERWATCH_MASTER' && isAdmin());
    }

    // --- COLLECTION RULES ---

    // Assets Marketplace (Bosses)
    match /bosses/{bossId} {
      allow read: if true;
      
      allow create: if request.auth != null 
                    && (request.resource.data.status == 'pending' || isAdmin())
                    && request.resource.data.contributorId == request.auth.uid;
      
      allow update: if isAdmin() || (
        request.auth != null 
        && resource.data.contributorId == request.auth.uid 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'contributorId']))
      );

      allow delete: if isAdmin() || canReadAdmin();
    }
    
    // Downloads Tracking
    match /downloads/{downloadId} {
      allow create: if request.auth != null;
      allow read: if isAdmin(); 
    }

    // User Profiles & Private Blueprints
    match /users/{userId} {
      allow read: if isOwner(userId) || canReadAdmin();
      
      allow write: if (
        isOwner(userId) 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      ) || isAdmin() || canReadAdmin();

      match /blueprints/{blueprintId} {
        allow read, write: if isOwner(userId) || canReadAdmin();
      }
    }
  }
}
